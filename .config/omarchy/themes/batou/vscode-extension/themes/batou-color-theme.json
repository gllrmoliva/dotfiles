  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7A8393"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#ACE1AF"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#CC6528"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#C75E57"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#C75E57"
      }
    },
    {
      "name": "Storage Types",
      "scope": [
        "storage.type",
        "storage",
        "keyword.type",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#E1D574"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#E19E74"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#E1D574"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#DBD9D3"
      }
    },
    {
      "name": "Parameters and Properties",
      "scope": [
        "variable.parameter",
        "variable.other.member",
        "meta.object-literal.key",
        "support.variable.property",
        "entity.name.variable.field"
      ],
      "settings": {
        "foreground": "#77899A"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#C75E57"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#E19E74"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#B3ADAD"
      }
    },
    {
      "name": "Modules and Namespaces",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#9577B6"
      }
    },
    {
      "name": "Escapes and Regular Expressions",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#5D8AA8"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
